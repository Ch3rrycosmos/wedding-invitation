# =============================================================================
# Wedding Invitation — Full Configuration
# =============================================================================
# Copy this file to .env.local and fill in your real details.
# .env.local is gitignored and never committed.
#
# All vars are NEXT_PUBLIC_ because they display on the page.
# They end up in the deployed HTML/JS — that's expected.
# =============================================================================

# ---- COUPLE ----
NEXT_PUBLIC_BRIDE_NAME=Ananya
NEXT_PUBLIC_GROOM_NAME=Arjun
# Only needed if you want something different from "A & A"
NEXT_PUBLIC_COUPLE_MONOGRAM=

# ---- DATE & TIME ----
NEXT_PUBLIC_WEDDING_DATE_ISO=2026-01-01T11:00:00
NEXT_PUBLIC_WEDDING_DATE_DISPLAY=1st January 2026
NEXT_PUBLIC_WEDDING_DAY_DISPLAY=Sunday
NEXT_PUBLIC_WEDDING_TIME_DISPLAY=11:00 AM

# ---- EVENT ----
NEXT_PUBLIC_EVENT_LABEL=Ceremony

# ---- VENUE ----
NEXT_PUBLIC_VENUE_NAME=The Grand Palace
NEXT_PUBLIC_VENUE_ADDRESS=Jaipur, Rajasthan
# Google Maps "Embed a map" iframe src (Share > Embed a map)
NEXT_PUBLIC_VENUE_MAPS_EMBED_SRC=
# Google Maps directions/search link
NEXT_PUBLIC_VENUE_MAPS_DIRECTIONS_URL=https://maps.google.com
NEXT_PUBLIC_VENUE_DESCRIPTION=Set among manicured emerald gardens and candlelit pathways, our venue offers an intimate, elegant backdrop for celebrating the beginning of our forever.

# ---- ENVELOPE / CARD ----
NEXT_PUBLIC_INVITATION_LINE=You are lovingly invited...
NEXT_PUBLIC_CARD_LABEL=INVITATION
NEXT_PUBLIC_TAP_TO_OPEN_TEXT=TAP TO OPEN

# ---- WELCOME SECTION ----
NEXT_PUBLIC_WELCOME_SECTION_LABEL=WITH JOYFUL HEARTS
NEXT_PUBLIC_WELCOME_QUOTE=Two souls, one heart, endless journey.
NEXT_PUBLIC_WELCOME_PARAGRAPH=Together with our families, we joyfully invite you to witness the beginning of our forever — an evening of love, laughter, and timeless celebration.

# ---- DETAILS SECTION ----
NEXT_PUBLIC_DETAILS_SECTION_LABEL=WEDDING DETAILS
NEXT_PUBLIC_DETAILS_SECTION_TITLE=When & Where
NEXT_PUBLIC_DETAILS_DATE_LABEL=Date
NEXT_PUBLIC_DETAILS_VENUE_LABEL=Venue

# ---- COUNTDOWN SECTION ----
NEXT_PUBLIC_COUNTDOWN_SECTION_LABEL=COUNTING DOWN TO FOREVER
NEXT_PUBLIC_COUNTDOWN_SECTION_TITLE=Until We Say "I Do"
NEXT_PUBLIC_COUNTDOWN_LABEL_DAYS=Days
NEXT_PUBLIC_COUNTDOWN_LABEL_HOURS=Hours
NEXT_PUBLIC_COUNTDOWN_LABEL_MINUTES=Minutes
NEXT_PUBLIC_COUNTDOWN_LABEL_SECONDS=Seconds

# ---- GALLERY SECTION ----
NEXT_PUBLIC_GALLERY_SECTION_LABEL=MOMENTS
NEXT_PUBLIC_GALLERY_SECTION_TITLE=Our Gallery
# Comma-separated captions (use \n for newline, but usually just commas)
NEXT_PUBLIC_GALLERY_CAPTIONS=Ananya & Arjun,Together With Their Families
# Comma-separated image paths (must match number of captions)
NEXT_PUBLIC_GALLERY_IMAGES=/gallery/couple-01.jpg,/gallery/invitation-card.png

# ---- VENUE SECTION ----
NEXT_PUBLIC_VENUE_SECTION_LABEL=FIND US
NEXT_PUBLIC_VENUE_SECTION_TITLE=The Venue
NEXT_PUBLIC_VENUE_DIRECTIONS_TEXT=GET DIRECTIONS

# ---- BLESSINGS SECTION ----
NEXT_PUBLIC_BLESSING_TITLE=With Love & Gratitude
NEXT_PUBLIC_BLESSING_MESSAGE=Your presence is the greatest gift we could ask for. We can't wait to celebrate this new beginning surrounded by the people who mean the most to us.

# ---- MUSIC ----
NEXT_PUBLIC_MUSIC_FILE=/song.mp3
# 0.0 to 1.0
NEXT_PUBLIC_MUSIC_VOLUME=0.4

# ---- SEO / META ----
NEXT_PUBLIC_SITE_TITLE=
NEXT_PUBLIC_SITE_DESCRIPTION=
