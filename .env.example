# Copy this file to .env.local and fill in the real details.
# .env.local is gitignored and is never committed — this keeps names,
# venue, address, and date/time out of the public repo and its history.
#
# These are NEXT_PUBLIC_ vars because the invitation page displays them
# directly to visitors, so they still end up in the deployed site's HTML/JS —
# that's expected. The point is keeping them out of source control, not
# hiding them from people you actually send the invite to.

NEXT_PUBLIC_BRIDE_NAME=Bride
NEXT_PUBLIC_GROOM_NAME=Groom

NEXT_PUBLIC_WEDDING_DATE_ISO=2026-01-01T11:00:00
NEXT_PUBLIC_WEDDING_DATE_DISPLAY=1st January 2026
NEXT_PUBLIC_WEDDING_DAY_DISPLAY=Sunday
NEXT_PUBLIC_WEDDING_TIME_DISPLAY=11:00 AM – 12:00 PM

NEXT_PUBLIC_EVENT_LABEL=Muhoortham

NEXT_PUBLIC_VENUE_NAME=Venue Name
NEXT_PUBLIC_VENUE_ADDRESS=City, State

# Google Maps "Embed a map" iframe src (Share > Embed a map)
NEXT_PUBLIC_VENUE_MAPS_EMBED_SRC=
# Google Maps directions/search link
NEXT_PUBLIC_VENUE_MAPS_DIRECTIONS_URL=
