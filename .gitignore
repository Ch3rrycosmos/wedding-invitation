# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real wedding details (names, venue, date/time) live in
# .env.local and must never be committed; .env.example is a safe template
.env*
!.env.example

# vercel
.vercel

# real wedding photos — kept locally/deployed separately, not published to the repo
/public/gallery/*
!/public/gallery/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
